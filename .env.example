# ================================================================
#  mvz-axo Research Platform — Environment Variables
#  Project: mAb (monoclonal antibody development, target biology,
#           epitope mapping, clinical antibody pipelines)
#
#  SETUP
#  ─────
#  cp .env.example .env
#  Fill in values below, then: source .env
#  NEVER commit .env to git — it is in .gitignore
#
#  KEY GUIDE
#  ─────────
#  🆓 FREE    No cost, registration only
#  💳 PAID    Free tier available; costs scale with use
#  🔒 REQ     Required for a specific tool/server to function
#  ⭐ REC     Recommended — significantly improves capability
#  ⏱ 2 min   Approximate time to obtain the key
#
#  PRIORITY ORDER FOR SETUP
#  ────────────────────────
#  1. NCBI_API_KEY          (🆓 ⭐ — unlocks PubMed rate limits)
#  2. BIOPORTAL_API_KEY     (🆓 🔒 — required for BioOntology MCP)
#  3. ANTHROPIC_API_KEY     (💳 ⭐ — primary reasoning model)
#  4. BRAVE_API_KEY         (💳 ⭐ — web search for agents)
#  5. GITHUB_TOKEN          (🆓 ⭐ — GitHub MCP)
#  6. HUGGINGFACE_TOKEN     (🆓 — gated models like MedGemma)
#  7. S2_API_KEY            (🆓 ⭐ — Semantic Scholar full access)
#  8. CROSSREF_MAILTO       (🆓 ⭐ — just an email, polite pool)
#  9. OPENROUTER_API_KEY    (💳 — model variety + frontier access)
# 10. RUNPOD_API_KEY        (💳 — GPU training)
# ================================================================


# ── Biomedical Data APIs ─────────────────────────────────────────────────────

# NCBI E-utilities — PubMed, Gene, ClinicalTrials.gov, Nucleotide, etc.
# 🆓 FREE | ⭐ STRONGLY REC | ⏱ 2 min
# Without key: 3 requests/sec. With key: 10 requests/sec.
# Used by: BioMCP, PubMed MCP, NCBI Datasets MCP, ct-mcp (custom)
# ① Go to: https://www.ncbi.nlm.nih.gov/account/
# ② Sign in or create free account
# ③ Click your username → My NCBI → API Key Management → Create API Key
NCBI_API_KEY=

# BioPortal / BioOntology — 1,200+ biological ontologies (MeSH, SNOMED, GO, etc.)
# 🆓 FREE | 🔒 REQUIRED for BioOntology MCP server | ⏱ 2 min
# Used by: BioOntology MCP server
# ① Go to: https://bioportal.bioontology.org/accounts/new
# ② Register (institutional email preferred but not required)
# ③ Key appears on your account page immediately after registration
BIOPORTAL_API_KEY=

# Semantic Scholar — 214M+ academic papers, open-access PDFs, citation graph
# 🆓 FREE | ⭐ REC — lifts rate limit from 1 req/5sec to 1 req/sec | ⏱ 3 min
# Used by: BioMCP article recommendations, literature search
# ① Fill the form at: https://www.semanticscholar.org/product/api#api-key-form
# ② Key emailed within minutes
S2_API_KEY=

# Europe PMC — European life sciences literature + preprints
# 🆓 FREE | No key required for basic use
# Registering your email gives access to Annotations API and higher quotas.
# Register: https://europepmc.org/annotations
# Leave empty for unauthenticated access (still functional)
EUROPEPMC_EMAIL=

# CrossRef — DOI metadata, citation counts, journal + publisher info
# 🆓 FREE | ⭐ REC — just an email address unlocks 50 req/sec "polite pool"
# Leave empty for unauthenticated access (1 req/sec, works but slower)
# Docs: https://www.crossref.org/documentation/retrieve-metadata/rest-api/
CROSSREF_MAILTO=

# OpenAlex — Open research knowledge graph (209M+ works, fully open)
# 🆓 FREE | ⭐ REC — email address gives "polite pool" (100K req/day)
# Without email: shared pool, may be throttled. With email: dedicated pool.
# Docs: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_EMAIL=

# DrugBank — comprehensive drug database (structures, targets, interactions, ADMET)
# 🆓 ACADEMIC FREE | Requires institutional affiliation
# ① Apply at: https://go.drugbank.com/users/sign_up (select Academic/Research)
# ② Academic license usually approved within 24–48 hours
# Leave empty to use only ChEMBL + BioMCP (which covers most drug queries)
DRUGBANK_API_KEY=

# The Lens — patents + scholarly literature (complementary to PubMed)
# 🆓 FREE | ⭐ REC for patent-clinical trial linkage research
# Register: https://www.lens.org/lens/user/subscriptions#scholar
# Provides: Scholarly API (200 req/min) + Patent API (10 req/min)
LENS_API_KEY=


# ── LLM — Primary Reasoning ──────────────────────────────────────────────────

# Anthropic Claude — primary AI reasoning model for this platform
# 💳 PAID | ⭐ STRONGLY REC | Claude Sonnet: $3/$15 per MTok (in/out)
# Used by: all agent personas, hypothesis generation, evidence synthesis
# ① Register: https://console.anthropic.com
# ② Add billing: https://console.anthropic.com/settings/billing
# ③ Generate key: https://console.anthropic.com/settings/keys
# Tip: Set a monthly spend cap to avoid surprises
ANTHROPIC_API_KEY=

# OpenRouter — unified API for 200+ models (Claude, GPT, Gemini, open weights)
# 💳 PAID | pay-per-token, no subscription | ⏱ 3 min
# Useful for: model comparison, accessing models not on Anthropic API,
#             routing to cheaper models for bulk tasks
# ① Register: https://openrouter.ai/
# ② Add credits: https://openrouter.ai/credits (minimum $5)
# ③ Generate key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# HuggingFace — required for downloading gated models (MedGemma, Llama 3, etc.)
# 🆓 FREE | 🔒 REQ for gated models | ⏱ 2 min
# Used by: Ollama model pulls, Unsloth Studio training, fastembed downloads
# ① Register: https://huggingface.co/join
# ② Generate token: https://huggingface.co/settings/tokens
#    → Create new token → Type: Read → Name: research-platform
# ③ Accept model licenses individually:
#    MedGemma:  https://huggingface.co/google/medgemma-4b-it
#    Llama 3:   https://huggingface.co/meta-llama/Meta-Llama-3-8B
#    MedLLaMA:  https://huggingface.co/meta-llama/Llama-2-7b-hf
HUGGINGFACE_TOKEN=


# ── LLM — Local via Ollama (already installed, no key needed) ────────────────

# Ollama — local open-weight model runtime, already installed + GPU-enabled
# No API key required. Runs at http://localhost:11434
# Pull models with: ollama pull <model_name>
#
# RECOMMENDED MODELS FOR MONOCLONAL ANTIBODY RESEARCH:
#   Medical/clinical:
#     ollama pull medgemma1.5      # ✅ Already loaded — Google MedGemma 1.5B
#     ollama pull meditron:7b      # 3.8GB — immediate medical QA
#     ollama pull meditron:70b     # 39GB — best open medical reasoning (needs 48GB VRAM)
#   General reasoning:
#     ollama pull qwen3.5:9b       # ✅ Already loaded — strong science reasoning
#     ollama pull gemma4:26b       # ✅ Already loaded — multimodal, 26B
#   Embedding (pick one, use consistently):
#     ollama pull nomic-embed-text # ✅ Already loaded — 274MB, recommended
#     ollama pull mxbai-embed-large# 670MB — higher quality
#     ollama pull bge-m3           # 1.2GB — best multilingual
OLLAMA_BASE_URL=http://localhost:11434


# ── Web Search ───────────────────────────────────────────────────────────────

# Brave Search — privacy-respecting web search API for AI agents
# 💳 PAID | 🆓 Free tier: 2,000 queries/month | ⭐ REC | ⏱ 2 min
# Used by: Brave Search MCP server (lets agents search the web)
# ① Register: https://api.search.brave.com/app/keys
# ② Free Data for AI plan: 2,000 queries/month, no credit card required
# ③ Paid: $3 per 1,000 queries above free tier
# MCP install: npx -y @modelcontextprotocol/server-brave-search
BRAVE_API_KEY=


# ── Infrastructure — Vector Database ─────────────────────────────────────────

# Qdrant — semantic vector search, already running on this machine
# No API key needed for local instances (leave QDRANT_API_KEY empty)
# Running at: http://localhost:6333 (opened to LAN by Ollama config)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# File-based local storage path (no Docker needed — Qdrant manages files here):
QDRANT_LOCAL_PATH=${HOME}/.local/share/qdrant/mAb


# ── Infrastructure — Graph Database ──────────────────────────────────────────

# Neo4j — local knowledge graph database
# 🆓 FREE Community Edition
# Install (Docker): docker run -d --name neo4j \
#   -p 7474:7474 -p 7687:7687 \
#   -e NEO4J_AUTH=neo4j/yourpassword \
#   -e NEO4J_PLUGINS='["apoc"]' \
#   neo4j:community
# Or download Desktop: https://neo4j.com/download/
# Docs: https://neo4j.com/docs/
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=


# ── Source Control + Project ─────────────────────────────────────────────────

# GitHub — already active via Zed extension; also used by GitHub MCP server
# 🆓 FREE | ⏱ 2 min
# ① Go to: https://github.com/settings/tokens
# ② Generate new token (classic) → Name: research-platform
# ③ Scopes: repo (full), read:org, read:user
GITHUB_TOKEN=
GITHUB_OWNER=mvz-axo
GITHUB_REPO=mAb


# ── GPU Cloud — Model Fine-Tuning ────────────────────────────────────────────

# RunPod — on-demand GPU cloud for model fine-tuning via Unsloth
# 💳 PAID | pay-per-second billing | RTX 4090: ~$0.34/hr | H100: ~$2.49/hr
# Used by: Unsloth Studio (already installed), arsenal-mcp-runpod (kask)
# ① Register: https://www.runpod.io/
# ② Add credits: https://www.runpod.io/console/user/billing
# ③ API key: https://www.runpod.io/console/user/settings → API Keys → + API Key
RUNPOD_API_KEY=


# ── Arsenal MCP Servers (Kask substrate, binaries in ~/.local/bin/) ──────────
#
# These binaries are pre-built and installed. They read credentials from this
# file via the wrapper scripts in .config/mcp/. No separate API keys needed —
# they use QDRANT_URL, QDRANT_API_KEY, and OLLAMA_BASE_URL from above.
#
# arsenal-mcp-embedding   — PDF/MD → chunk → embed → Qdrant (7 tools)
#   Launch: .config/mcp/run-embedding.sh
#
# arsenal-mcp-rss-reader  — RSS/Atom/JSON feed reader (19 tools)
#   Launch: .config/mcp/run-rss-reader.sh
#   Suggested feeds for mAb research:
#     Nature Immunology:    https://www.nature.com/nri.rss
#     J Immunology:         https://www.jimmunol.org/rss/current.xml
#     mAbs journal:         https://www.tandfonline.com/feed/rss/kmab20
#     Cancer Immunol Res:   https://cancerimmunolres.aacrjournals.org/rss/current.xml
#     BioDrugs:             https://link.springer.com/search.rss?query=monoclonal+antibody
#     FDA Biologics:        https://www.fda.gov/about-fda/contact-fda/stay-informed/rss-feeds/biologics/rss.xml
#
# arsenal-mcp-logseq      — Logseq knowledge graph CRUD (read/write pages)
#   Launch: .config/mcp/run-logseq.sh
#   Graph path: knowledge/logseq/
#
# Embedding model (must match what's in Ollama — do not mix models in one collection):
ARSENAL_EMBEDDING_MODEL=nomic-embed-text
ARSENAL_EMBEDDING_DIMENSIONS=768
# Log level for all Rust binaries (trace | debug | info | warn | error):
RUST_LOG=info


# ── Unsloth Studio (already installed + running as systemd service) ───────────
#
# Unsloth Studio is a local web UI for training and running LLMs.
# Service: systemctl --user status unsloth-studio
# Access:  http://192.168.18.47:8888
# Launch script: .config/unsloth/launch-studio.sh
#
# To change the Studio password:
#   unsloth studio reset-password
# Bootstrap password saved at: ~/.unsloth/studio/auth/.bootstrap_password
#
# No API keys needed for local training. RunPod key above enables cloud GPU training.
